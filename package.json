{
  "name": "ch57x-keyboard-configurator",
  "version": "1.0.0",
  "description": "Mac app to configure your 3-key + knob CH57x keyboard and LED colors",
  "repository": {
    "type": "git",
    "url": "git@github.com:BodhiMooij/ch57x-keyboard-configurator.git"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "electron .",
    "electron:dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && electron . --dev\"",
    "electron:build": "next build && electron-builder --mac"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@serialport/parser-readline": "^12.0.0",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.bodhimooij.ch57x-keyboard-configurator",
    "productName": "CH57x Keyboard Configurator",
    "publish": null,
    "mac": {
      "category": "public.app-category.utilities",
      "target": ["dmg", "zip"],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "files": ["out", "electron", "package.json"],
    "directories": {
      "output": "dist"
    }
  }
}
